  "dictate_toggle":   { "target": "powerscribe", "keys": "{F4}",    "haptic": "dictate_on",  "label": "dictate" },
  "ps_field_prev":    { "target": "powerscribe", "keys": "+{Tab}",  "haptic": "",            "label": "prev field" },
  "ps_field_next":    { "target": "powerscribe", "keys": "{Tab}",   "haptic": "",            "label": "next field" },

  "mouse_lclick":     { "target": "mouse",  "keys": "", "haptic": "",               "label": "L-click" },
  "mouse_rclick":     { "target": "mouse",  "keys": "", "haptic": "",               "label": "R-click" },
  "mouse_mclick":     { "target": "mouse",  "keys": "", "haptic": "",               "label": "M-click" },
  "mouse_ldown":      { "target": "mouse",  "keys": "", "haptic": "",               "label": "L-down" },
  "mouse_lup":        { "target": "mouse",  "keys": "", "haptic": "",               "label": "L-up" },
  "precision_toggle": { "target": "mouse",  "keys": "", "haptic": "",               "label": "precision" },

  "hud_toggle":       { "target": "script", "keys": "", "haptic": "",               "label": "HUD" }
